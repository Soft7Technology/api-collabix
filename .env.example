PORT=8000
DATABASE_URL=postgresql://username:password@hostname:port/dbname
NODE_ENV=production

# JWT secrets for secure cookie sessions (replace with long, random strings in production)
JWT_ACCESS_SECRET=your_jwt_access_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_chars_long
JWT_ACCESS_EXPIRES_IN=4h
JWT_REFRESH_EXPIRES_IN=30d

# Customer app URL used in invitation and password-reset emails
FRONTEND_URL=https://app.yourdomain.com

# Comma-separated customer and administration frontend origins
FRONTEND_URLS=https://app.yourdomain.com,https://admin.yourdomain.com

# Required only while running `npm run seed-admin`
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Email provider configuration (use 'smtp' or 'console')
EMAIL_PROVIDER=smtp

# SMTP settings
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Collabix Onboarding <no-reply@yourdomain.com>

# IMAP/POP settings (optional/for reference)
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
POP_HOST=pop.hostinger.com
POP_PORT=995

